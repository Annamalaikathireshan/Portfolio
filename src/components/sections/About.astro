---
const { about, sectionIndex } = Astro.props;
---

<section id="about" class="about">
  <div class="container">
    <p class="section-label reveal">{sectionIndex?.about || '01'} — about</p>
    <h2 class="section-title reveal">About</h2>
    <p class="about-prose reveal">{about.prose}</p>
    <div class="about-stats reveal">
      {about.stats.map((stat: { value: number; label: string; suffix?: string }) => (
        <div class="stat-item">
          <span class="stat-number" data-target={stat.value} data-suffix={stat.suffix || ''}>0</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
