---
const { about } = Astro.props;
---

<section id="about" class="about">
  <div class="container">
    <h2 class="section-title">About Me</h2>
    <div class="about-features">
      {about.pillars.map((pillar: { title: string; description: string; icon: string }, i: number) => (
        <div class={`feature-card reveal reveal-child`} style={`transition-delay: ${i * 100}ms`}>
          <div class="feature-icon">
            {pillar.icon === 'layers' && (
              <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
            )}
            {pillar.icon === 'heart' && (
              <svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" /></svg>
            )}
            {pillar.icon === 'users' && (
              <svg viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            )}
            {pillar.icon === 'database' && (
              <svg viewBox="0 0 24 24">
                <ellipse cx="12" cy="5" rx="9" ry="3" />
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
              </svg>
            )}
            {pillar.icon === 'cube' && (
              <svg viewBox="0 0 24 24">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
              </svg>
            )}
            {pillar.icon === 'clock' && (
              <svg viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            )}
          </div>
          <h3>{pillar.title}</h3>
          <p>{pillar.description}</p>
        </div>
      ))}
    </div>
    <div class="about-stats reveal">
      {about.stats.map((stat: { value: number; label: string; suffix?: string }) => (
        <div class="stat-item stat-glass">
          <span class="stat-number" data-target={stat.value} data-suffix={stat.suffix || ''}>0</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
