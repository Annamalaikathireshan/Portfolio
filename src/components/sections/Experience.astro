---
const { experience, sectionIndex } = Astro.props;
---

<section id="experience" class="experience">
  <div class="container">
    <p class="section-label reveal">{sectionIndex?.experience || '04'} — experience</p>
    <h2 class="section-title reveal">{experience.title}</h2>
    <div class="experience-list">
      <span class="timeline-line" aria-hidden="true"></span>
      {experience.items.map((job: {
        role: string;
        company: string;
        date: string;
        highlights: string[];
      }) => (
        <div class="experience-entry">
          <div class="experience-date">{job.date}</div>
          <div class="experience-main">
            <h3>{job.role}</h3>
            <p class="experience-company">{job.company}</p>
            <ul class="experience-highlights">
              {job.highlights.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
