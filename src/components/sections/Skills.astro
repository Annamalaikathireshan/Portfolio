---
const { skills, sectionIndex } = Astro.props;
const marqueeItems: string[] = skills.categories.flatMap(
  (cat: { items: string[] }) => cat.items
);
---

<section id="skills" class="skills">
  <div class="skills-marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <span class="marquee-item">{item}<span class="marquee-sep">·</span></span>
      ))}
    </div>
  </div>
  <div class="container">
    <p class="section-label reveal">{sectionIndex?.skills || '02'} — stack</p>
    <h2 class="section-title reveal">{skills.title}</h2>
    <div class="skills-categories reveal">
      {skills.categories.map((cat: { title: string; items: string[] }) => (
        <div class="skill-row">
          <span class="skill-category-label">{cat.title}</span>
          {cat.items.map((item: string) => (
            <span class="skill-item">{item}</span>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
