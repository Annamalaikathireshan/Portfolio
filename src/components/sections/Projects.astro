---
const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section id="projects" class="projects">
  <div class="container">
    <h2 class="section-title">{projects.title}</h2>
    <div class="projects-grid">
      {projects.items.map((project: {
        title: string;
        description: string;
        logo?: string;
        icon?: string;
        tags: string[];
      }, i: number) => (
        <div class="project-card reveal reveal-child" style={`transition-delay: ${i * 100}ms`}>
          <div class="project-icon">
            {project.logo ? (
              <img
                src={project.logo.startsWith('/') ? `${base}${project.logo.slice(1)}` : project.logo}
                alt={project.title}
              />
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" width="40" height="40">
                <ellipse cx="12" cy="5" rx="9" ry="3" />
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
              </svg>
            )}
          </div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="project-tags">
            {project.tags.map((tag: string) => (
              <span class="project-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
