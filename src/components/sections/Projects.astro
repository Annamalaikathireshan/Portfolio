---
const { projects, sectionIndex } = Astro.props;
---

<section id="projects" class="projects">
  <div class="container projects-header">
    <p class="section-label reveal">{sectionIndex?.projects || '03'} — work</p>
    <h2 class="section-title reveal">{projects.title}</h2>
  </div>
  <div class="projects-gallery">
    <div class="container projects-gallery-inner">
      <div class="case-studies">
      {projects.items.map((project: {
        title: string;
        client: string;
        period: string;
        context: string;
        built: string;
        outcome: string;
        stack: string[];
        link?: string;
      }, i: number) => (
        <article class="case-study reveal reveal-child" style={`transition-delay: ${i * 80}ms`}>
          <div class="case-study-header">
            <h3>{project.title}</h3>
            <span class="case-study-meta">{project.client} · {project.period}</span>
          </div>
          <div class="case-study-body">
            <div class="case-field">
              <span class="case-field-label">context</span>
              <span class="case-field-value">{project.context}</span>
            </div>
            <div class="case-field">
              <span class="case-field-label">built</span>
              <span class="case-field-value">{project.built}</span>
            </div>
            <div class="case-field">
              <span class="case-field-label">outcome</span>
              <span class="case-field-value">{project.outcome}</span>
            </div>
            <div class="case-field">
              <span class="case-field-label">stack</span>
              <span class="case-field-value">
                <span class="case-stack">
                  {project.stack.map((tag: string) => (
                    <code class="code-tag">{tag}</code>
                  ))}
                </span>
              </span>
            </div>
            {project.link && (
              <div class="case-field">
                <span class="case-field-label">code</span>
                <span class="case-field-value">
                  <a href={project.link} target="_blank" rel="noopener noreferrer" class="case-link">
                    {project.link.replace('https://', '')} ↗
                  </a>
                </span>
              </div>
            )}
          </div>
        </article>
      ))}
      </div>
    </div>
  </div>
</section>
