---
const { learning, sectionIndex } = Astro.props;
---

<section id="learning" class="learning">
  <div class="container">
    <p class="section-label reveal">{sectionIndex?.learning || '02'} — learning log</p>
    <h2 class="section-title reveal">{learning.title}</h2>
    {learning.subtitle && <p class="section-subtitle reveal">{learning.subtitle}</p>}
    <div class="learning-log">
      {learning.items.map((item: { step: string; title: string; description: string }, i: number) => (
        <div class="learning-entry reveal reveal-child" style={`transition-delay: ${i * 50}ms`}>
          <span class="learning-index">{item.step}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
