---
const { contact, sectionIndex } = Astro.props;
---

<section id="contact" class="contact">
  <div class="container contact-container reveal">
    <p class="section-label">{sectionIndex?.contact || '05'} — contact</p>
    <h2 class="section-title">Contact</h2>
    <p>{contact.message}</p>
    <a href={`mailto:${contact.email}`} class="contact-email">{contact.email}</a>
    <div class="social-links">
      {contact.socials.map((social: { label: string; href: string; icon: string }) => (
        <a href={social.href} target="_blank" rel="noopener noreferrer" class="social-btn" aria-label={social.label}>
          {social.icon === 'github' && (
            <svg viewBox="0 0 24 24">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          )}
          {social.icon === 'linkedin' && (
            <svg viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
