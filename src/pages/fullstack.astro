---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollProgress from '../components/ui/ScrollProgress.astro';
import Header from '../components/ui/Header.astro';
import RoleSwitcher from '../components/ui/RoleSwitcher.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Skills from '../components/sections/Skills.astro';
import ArchitectureStrip from '../components/sections/ArchitectureStrip.astro';
import Projects from '../components/sections/Projects.astro';
import Experience from '../components/sections/Experience.astro';
import Contact from '../components/sections/Contact.astro';
import data from '../data/fullstack.json';
---

<BaseLayout
  title={`Annamalai Kathiresan | ${data.jobTitle}`}
  description={data.metaDescription}
  role={data.id}
  jobTitle={data.jobTitle}
>
  <ScrollProgress />
  <Header nav={data.nav} current={data.id}>
    <RoleSwitcher slot="role-switcher" current={data.id} />
  </Header>

  <main>
    <Hero data={data} />
    <About about={data.about} />
    {data.architectureStrip && (
      <section class="about">
        <div class="container">
          <ArchitectureStrip strip={data.architectureStrip} />
        </div>
      </section>
    )}
    <Skills skills={data.skills} />
    <Projects projects={data.projects} />
    <Experience experience={data.experience} />
    <Contact contact={data.contact} />
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2026 Annamalai Kathiresan. All rights reserved.</p>
    </div>
  </footer>

  <script src="../scripts/portfolio.ts"></script>
</BaseLayout>
