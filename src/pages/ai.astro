---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollProgress from '../components/ui/ScrollProgress.astro';
import Header from '../components/ui/Header.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Skills from '../components/sections/Skills.astro';
import Projects from '../components/sections/Projects.astro';
import Experience from '../components/sections/Experience.astro';
import Contact from '../components/sections/Contact.astro';
import data from '../data/ai.json';
---

<BaseLayout
  title={`Annamalai Kathiresan | ${data.jobTitle}`}
  description={data.metaDescription}
  role={data.id}
  jobTitle={data.jobTitle}
>
  <ScrollProgress />
  <Header nav={data.nav} />

  <main>
    <Hero data={data} />
    <About about={data.about} sectionIndex={data.sectionIndex} />
    <Skills skills={data.skills} sectionIndex={data.sectionIndex} />
    <Projects projects={data.projects} sectionIndex={data.sectionIndex} />
    <Experience experience={data.experience} sectionIndex={data.sectionIndex} />
    <Contact contact={data.contact} sectionIndex={data.sectionIndex} />
  </main>

  <footer>
    <div class="container">
      <p>© 2026 Annamalai Kathiresan</p>
    </div>
  </footer>

  <script src="../scripts/portfolio.ts"></script>
</BaseLayout>
