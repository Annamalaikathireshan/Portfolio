---
import HubLayout from '../layouts/HubLayout.astro';
import PortfolioCard from '../components/hub/PortfolioCard.astro';
import hub from '../data/hub.json';
---

<HubLayout
  title="Annamalai Kathiresan | Portfolio Selection"
  description="Choose a specialized portfolio — Front-end Architect, Full Stack Developer, or AI Engineer."
>
  <div class="hub-container">
    <p class="hub-eyebrow">Portfolio Hub</p>
    <h1 class="hub-title">{hub.name}</h1>
    <p class="hub-tagline">{hub.tagline}</p>
    <p class="hub-subtitle">{hub.subtitle}</p>

    <div class="portfolio-grid reveal">
      {hub.cards.map((card) => (
        <PortfolioCard card={card} />
      ))}
    </div>
  </div>

  <script src="../scripts/hub.ts"></script>
</HubLayout>
